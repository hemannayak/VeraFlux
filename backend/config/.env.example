# Veraflux Environment Configuration
# Copy this file to .env and update with your actual values

# Environment
ENVIRONMENT=development

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/veraflux
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Vector Store Configuration
VECTOR_DB_URL=http://localhost:8080
VECTOR_DB_API_KEY=your-vector-db-api-key
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=768

# API Configuration
API_TITLE=Veraflux API
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=60

# Data Ingestion Configuration
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
NEWS_API_KEY=your-news-api-key
SENSOR_API_ENDPOINTS=http://sensor1.example.com,http://sensor2.example.com
INGESTION_INTERVAL_SECONDS=60
MAX_EVENTS_PER_BATCH=100

# Data Processing Configuration
CONTENT_SIMILARITY_THRESHOLD=0.8
TIME_THRESHOLD_MINUTES=30
LOCATION_THRESHOLD_KM=5.0
DEDUPLICATION_BATCH_SIZE=1000
MAX_PROCESSING_WORKERS=4

# Verification Configuration
MIN_CREDIBILITY_THRESHOLD=0.5
MAX_FILE_SIZE_MB=50
ALLOWED_MEDIA_TYPES=image/jpeg,image/png,video/mp4
REVERSE_IMAGE_SEARCH_API_KEY=your-reverse-image-search-api-key

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-west-2
S3_BUCKET_NAME=your-s3-bucket
CACHE_TTL_SECONDS=3600

# Monitoring Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/veraflux.log
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30
ALERT_WEBHOOK_URL=your-alert-webhook-url
